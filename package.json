{
  "name": "neo-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "concurrently -n server,desktop -c green,cyan \"pnpm --filter @neo-companion/server-local dev\" \"pnpm --filter @neo-companion/desktop dev:web\"",
    "dev:tauri": "concurrently -n server,tauri -c green,cyan \"pnpm --filter @neo-companion/server-local dev\" \"pnpm --filter @neo-companion/desktop dev:tauri\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
